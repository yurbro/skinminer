{"hitCount": 1, "request": {"cursorMark": "*", "pageSize": 1, "queryString": "DOI:\"10.7748/ns2008.11.23.10.42.c6722\"", "resultType": "core", "sort": "", "synonym": false}, "resultList": {"result": [{"abstractText": "Painful chronic wounds have long been treated with dressings that provide moist wound healing. This moist environment, through limiting the exposure of nerve ends, ensures some pain relief. A foam dressing presents a new option for nurses treating chronic painful wounds. It combines the benefits of moist wound healing with a continuous release of ibuprofen into the wound and surrounding skin that is designed to reduce pain. This article describes this dressing, presents some of the clinical evidence to support its use and proposes a four-step wound pain management model.", "affiliation": "Women's College Hospital, Toronto, Canada.", "authMan": "N", "authorList": {"author": [{"authorAffiliationDetailsList": {"authorAffiliation": [{"affiliation": "Women's College Hospital, Toronto, Canada."}]}, "firstName": "Patricia", "fullName": "Coutts P", "initials": "P", "lastName": "Coutts"}, {"firstName": "Kevin Y", "fullName": "Woo KY", "initials": "KY", "lastName": "Woo"}, {"firstName": "Stephanie", "fullName": "Bourque S", "initials": "S", "lastName": "Bourque"}]}, "authorString": "Coutts P, Woo KY, Bourque S.", "chemicalList": {"chemical": [{"name": "Anti-Inflammatory Agents, Non-Steroidal", "registryNumber": "0"}]}, "citedByCount": 9, "dataLinksTagsList": {"dataLinkstag": ["wikipedia"]}, "dateOfCompletion": "2009-01-23", "dateOfCreation": "2008-12-06", "dateOfRevision": "2008-12-05", "doi": "10.7748/ns2008.11.23.10.42.c6722", "epmcAuthMan": "N", "firstIndexDate": "2009-01-25", "firstPublicationDate": "2008-11-01", "fullTextUrlList": {"fullTextUrl": [{"availability": "Subscription required", "availabilityCode": "S", "documentStyle": "doi", "site": "DOI", "url": "https://doi.org/10.7748/ns.23.10.42.s53"}, {"availability": "Subscription required", "availabilityC